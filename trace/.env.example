# Trace — environment template. Copy to .env (local) or paste into
# Vercel Project -> Settings -> Environment Variables (prod/preview).
# Never commit real values.

# --- Required ---
# Generate with: openssl rand -hex 32
SECRET_KEY=
# INVITE_CODE gates access to Neon Auth sign-in (closed-beta invariant).
INVITE_CODE=

# --- Neon Auth (Better Auth) — email-OTP ---
# Enable Neon Auth in the Neon console (Auth tab) and configure the email
# provider. Copy the "Auth URL" from that page — looks like:
#   https://ep-<name>-<region>.neonauth.<cloud>.neon.tech/<db>/auth
NEON_AUTH_URL=

# Database — Neon (use the POOLED connection string, host contains `-pooler`).
# Trace auto-normalizes this: `postgres://`/`postgresql://` -> `postgresql+psycopg://`
# and adds `sslmode=require` if absent.
# Example:
# DATABASE_URL=postgresql+psycopg://user:pw@ep-cool-name-pooler.us-east-1.aws.neon.tech/trace?sslmode=require
DATABASE_URL=

# --- LLM / retrieval ---
GEMINI_API_KEY=
EXA_API_KEY=

# --- Runtime ---
# ENV=prod on Vercel so session cookies are marked Secure.
ENV=dev
LOG_LEVEL=INFO
SESSION_MAX_AGE_SECONDS=28800

# Pipeline budget — conservative defaults for Vercel Hobby (60s maxDuration).
# Raise these only if on Pro (300s) and your Gemini/Exa quotas allow.
EXA_CONCURRENCY=3
MAX_DOCS_PER_QUERY=3
